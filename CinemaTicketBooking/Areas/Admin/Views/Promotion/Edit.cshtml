@model PromotionUpdateResponceVM
<div class="container">
    <div class="row mb-3 align-items-center my-3">
        <div class="col-md-6">
            <h3 class="display-6">Edit Actor</h3>
        </div>
    </div>

    <div class="row my-3">
        <div class="col-12">
            <form method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="promotion.Id" />
                <div class="mb-3">
                    <label for="Code" class="form-label">Name</label>
                    <input class="form-control" placeholder="Enter category name" asp-for="promotion.Code"
                           onchange="previewImage(event)">
                    <span asp-validation-for="promotion.Code" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label for="Discount" class="form-label">Discount</label>
                    <input class="form-control" placeholder="Enter promotion discount" asp-for="promotion.Discount">
                    <span asp-validation-for="promotion.Discount" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label for="Img" class="form-label">Img </label>
                    <input type="file" class="form-control" name="img" placeholder="Enter actor image">

                </div>
                <div class="mb-3">
                    <label for="ExpiredAt" class="form-label">Expired At Date</label>
                    <input asp-for="promotion.ExpiredAt" type="datetime-local" class="form-control" />

                </div>

                <div class="mb-3">
                    <label for="MovieId" class="form-label">Movie</label>
                    <select class="form-select" asp-for="promotion.MovieId">
                        @foreach (var movie in Model.movies ?? Enumerable.Empty<Movie>())
                        {
                            <option value="@movie.Id">@movie.Name</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label for="ApplicationUserId" class="form-label">User</label>
                    <select class="form-select" asp-for="promotion.ApplicationUserId">
                        @foreach (var user in Model.Users ?? Enumerable.Empty<ApplicationUser>())
                        {
                            <option value="@user.Id">@user.UserName</option>
                        }
                    </select>
                </div>
                <button type="submit" class="btn btn-primary">Submit</button>
            </form>
        </div>
    </div>
</div>
<script>
    function previewImage(event) {
    const input = event.target;
    const preview = document.getElementById('preview');
    if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = function(e) {
            preview.src = e.target.result;
        }
        reader.readAsDataURL(input.files[0]);
    }
</script>
@section Scripts {
    <partial name="~/Views/Shared/_NotificationPartial.cshtml" />
    <partial name="~/Views/Shared/_ValidationScriptsPartial.cshtml" />
}